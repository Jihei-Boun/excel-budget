# 가상환경
.venv/
venv/
env/

# 파이썬 캐시 / 빌드
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# 환경변수 / 로컬 설정
.env
.env.*
!.env.example

# 에디터 / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# 엑셀 임시 파일
~$*
*.tmp

# 실행 결과
data/output/*
!data/output/.gitkeep

# 입력 엑셀(업무 데이터) — 샘플을 공개하려면 이 블록을 지우세요
data/input/*
!data/input/.gitkeep
